        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;fontColor=#333333;fontSize=10;strokeColor=#BDBDBD;arcSize=6;" value="&lt;b&gt;Условные обозначения:&lt;/b&gt;&#xa;───── Пользовательский трафик&#xa;─ ─ ─ B2B партнёрский трафик&#xa;─ ─ ─ Репликация / Backup" vertex="1">
